# ============================================
# SynapSeed — Variables de entorno (ejemplo)
# ============================================
# Copiar este archivo a `.env` y rellenar los valores reales:
#   cp .env.example .env
# NUNCA commitear el archivo `.env` real al repositorio.

# -----------------------------------------------------------
# Entorno
# -----------------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------
# Base de datos PostgreSQL + pgvector
# -----------------------------------------------------------
# --- Supabase (recomendado) ---
# Obtener en: Supabase Dashboard → Settings → Database → Connection string → URI
# Usar pooler (port 6543) para conexiones async, directa (port 5432) para Alembic sync
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Opcional: operaciones admin (no requerido para login/registro básico)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- Local (docker-compose, alternativa a Supabase) ---
# DATABASE_URL=postgresql+asyncpg://synapseed:synapseed@localhost:5432/synapseed
# DATABASE_URL_SYNC=postgresql+psycopg2://synapseed:synapseed@localhost:5432/synapseed

# -----------------------------------------------------------
# Redis (broker de Celery, cache y pub/sub para SSE)
# -----------------------------------------------------------
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
API_V1_PREFIX=/api/v1
PROJECT_NAME=SynapSeed

# -----------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------
# Login del API usa cédula → busca email en tabla users → Supabase Auth.
# El JWT retornado es el access_token de Supabase (no un JWT local).
# En Supabase Dashboard → Authentication → Providers: habilitar Email.
# Para desarrollo: desactivar "Confirm email" si no quieres verificación.
# IMPORTANTE: generar un valor aleatorio seguro en producción
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# CORS: orígenes permitidos para el frontend
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# -----------------------------------------------------------
# OpenRouter (Chat LLM — API compatible con OpenAI)
# -----------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openrouter/free
OPENROUTER_RPM_LIMIT=20
OPENROUTER_MAX_RETRIES=5
OPENROUTER_EMBEDDING_DIM=768

# -----------------------------------------------------------
# Google Gemini (Embeddings — gratuito)
# -----------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# -----------------------------------------------------------
# Celery
# -----------------------------------------------------------
CELERY_TASK_TIME_LIMIT=600
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_CONCURRENCY=1

# -----------------------------------------------------------
# SSE (Server-Sent Events) para progreso del pipeline
# -----------------------------------------------------------
SSE_KEEPALIVE_INTERVAL=15
SSE_HEARTBEAT_TIMEOUT=120

# -----------------------------------------------------------
# Observabilidad
# -----------------------------------------------------------
SENTRY_DSN=
