# ============================================
# SynapSeed — Frontend env vars (ejemplo)
# ============================================
# Solo se exponen al cliente las variables prefijadas con VITE_.

# URL base del backend FastAPI
VITE_API_URL=http://localhost:8000/api/v1

# Nombre de la app (mostrado en el header / login)
VITE_APP_NAME=SynapSeed

# Versión (para mostrar en el footer / debugging)
VITE_APP_VERSION=0.1.0
